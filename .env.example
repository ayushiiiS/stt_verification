SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_MODEL=saaras:v3
SARVAM_STT_MODE=codemix
SARVAM_REQUEST_INTERVAL_SEC=1
SARVAM_PARALLEL_WORKERS=5
PORT=5050
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# Optional password overrides: username:password,username2:password2
# Default password for each user is their username
# AUTH_PASSWORDS=ayushi:secret,kriti:secret,akash:secret,yash:secret

# Google Cloud Storage persistence (required for deploy)
GCS_BUCKET=gotldenset
GCS_LOCATION=asia-south1
# Either set GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# or paste the full service-account JSON (or base64) here for Vercel:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Set to true to force local-only mode:
# GCS_DISABLED=false

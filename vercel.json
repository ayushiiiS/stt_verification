{
  "buildCommand": "mkdir -p public && rm -rf public/static && cp -R static public/static",
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!static/).*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "{templates/**,static/**}"
    }
  }
}

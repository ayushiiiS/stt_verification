{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "{data_calls.csv,data_transcripts.json,sarvam_transcripts.json,indiamart_63_transcripts.json,indiamart_final63_public_urls.csv,indiamart_sarvam_transcripts.json,templates/**,static/**}"
    }
  }
}
